{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --runInBand --config jest.config.js",
    "test:integration": "jest --runInBand --config jest.integration.config.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "empathic": "^2.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "fast-check": "^3.23.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.18.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
